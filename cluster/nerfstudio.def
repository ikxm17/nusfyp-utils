Bootstrap: docker
From: nvidia/cuda:11.8.0-devel-ubuntu22.04

%labels
    Author Irwin
    Description nerfstudio + sea-splatfacto training environment for Vanda HPC

%setup
    # Create mount points expected by the host's Apptainer bind-path config
    # Must be in %setup (not %post) so they exist before bind mounts are applied
    mkdir -p ${APPTAINER_ROOTFS}/app1
    mkdir -p ${APPTAINER_ROOTFS}/scratch

%files
    sea-splatfacto                    /opt/sea-splatfacto
    nerfstudio                        /opt/nerfstudio

%post
    # System packages
    export DEBIAN_FRONTEND=noninteractive
    apt-get update && apt-get install -y --no-install-recommends \
        git \
        build-essential \
        ffmpeg \
        python3 \
        python3-pip \
        python3-venv \
        python3-dev \
        ca-certificates \
        && rm -rf /var/lib/apt/lists/*

    # Create a venv so pip packages are isolated from system Python
    python3 -m venv /opt/venv
    export PATH="/opt/venv/bin:$PATH"
    pip install --upgrade pip

    # CUDA env vars — base image provides nvcc at /usr/local/cuda
    export CUDA_HOME=/usr/local/cuda
    # Compile CUDA kernels optimized for A40 (Ampere, compute capability 8.6)
    export TORCH_CUDA_ARCH_LIST="8.6"
    export TCNN_CUDA_ARCHITECTURES="86"

    # Pin numpy <2 to avoid ABI incompatibility with PyTorch 2.1.2
    pip install "numpy<2"

    # PyTorch (CUDA 11.8 wheels from pytorch.org)
    pip install \
        torch==2.1.2+cu118 \
        torchvision==0.16.2+cu118 \
        --extra-index-url https://download.pytorch.org/whl/cu118

    # tiny-cuda-nn — build from source using base image's nvcc
    pip install setuptools wheel ninja
    pip install --no-build-isolation git+https://github.com/NVlabs/tiny-cuda-nn/#subdirectory=bindings/torch

    # nerfstudio (non-editable — stable, not actively modified)
    # "numpy<2" is inline so pip's resolver respects the cap in the same pass
    pip install "numpy<2" /opt/nerfstudio
    # sea-splatfacto (editable — bind-mount picks up git pull changes without rebuild)
    pip install -e /opt/sea-splatfacto

    # CLI tab completions (non-fatal if it fails)
    ns-install-cli || true

    # Cleanup to reduce image size
    pip cache purge
    rm -rf /opt/sea-splatfacto/.git /opt/nerfstudio/.git

%environment
    export PATH="/opt/venv/bin:$PATH"
    export CUDA_HOME=/usr/local/cuda

%runscript
    exec "$@"
