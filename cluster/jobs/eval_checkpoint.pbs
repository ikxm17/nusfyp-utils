#!/bin/bash
#PBS -N ns-eval-ckpt
#PBS -l select=1:ngpus=1:ncpus=2:mem=16gb
#PBS -l walltime=02:00:00
#PBS -j oe
#PBS -o /scratch/e0908336/fyp-playground/logs/eval_checkpoint.log

# Evaluate at a specific checkpoint step.
# Required PBS variables (passed via qsub -v):
#   EXPERIMENT  — experiment path spec (e.g., "torpedo_unprocessed-repl00_anneal")
#   STEP        — checkpoint step number (e.g., 19999)
# Optional:
#   RENDER      — set to "true" to also render at that step

cd "$PBS_O_WORKDIR" || exit 1

CONTAINER=$HOME/workspace/fyp/containers/nerfstudio.sif
FYP_UTILS=$HOME/workspace/fyp/fyp-utils
OUTPUTS=/scratch/$USER/fyp-playground/outputs

echo "==> Job $PBS_JOBID started at $(date)"
echo "==> Node: $(hostname)"
echo "==> Experiment: ${EXPERIMENT:-UNSET}"
echo "==> Step: ${STEP:-UNSET}"

if [ -z "${EXPERIMENT:-}" ] || [ -z "${STEP:-}" ]; then
    echo "ERROR: EXPERIMENT and STEP must be set via -v"
    exit 1
fi

RENDER_FLAG=""
if [ "${RENDER:-false}" = "true" ]; then
    RENDER_FLAG="--render"
fi

export TORCHDYNAMO_DISABLE=1

apptainer exec --nv \
    --bind $HOME/workspace/fyp/sea-splatfacto:/opt/sea-splatfacto \
    --bind $HOME/workspace/fyp/nerfstudio:/opt/nerfstudio \
    --bind /scratch/$USER:/scratch/$USER \
    "$CONTAINER" \
    python "$FYP_UTILS/scripts/eval_checkpoint.py" \
        "$EXPERIMENT" \
        --step "$STEP" \
        --outputs-dir "$OUTPUTS" \
        $RENDER_FLAG

echo "==> Job finished at $(date)"
